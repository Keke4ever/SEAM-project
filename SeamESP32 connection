/*
   ESP32 BLE Bridge for SEAM
   ----------------------------------------
   Role 1: BLE Client to Raspberry Pi Zero 2W
   Role 2: BLE Server/Peripheral to Mobile/Web App
   Role 3: Update LCD with latest values

   Data flow:
   Pi Zero ---> ESP32 ---> LCD
                    \
                     ---> Mobile/Web App

   Expected Pi BLE payload examples:
   "HR:78,SPO2:98"
   or
   "78,98"

   App subscribes to notify characteristic on ESP32.
   App may also write commands to ESP32 using the write characteristic.
*/

#include <Arduino.h>
#include <NimBLEDevice.h>

// ======================================================
//                     USER SETTINGS
// ======================================================

// ---- Pi BLE Service / Characteristic UUIDs ----
// These MUST match the UUIDs used by the Raspberry Pi BLE peripheral
static const char* PI_SERVICE_UUID        = "12345678-1234-1234-1234-1234567890ab";
static const char* PI_CHARACTERISTIC_UUID = "abcd1234-5678-1234-5678-abcdef123456";

// ---- ESP32 BLE Service / Characteristic UUIDs for App ----
static const char* ESP_SERVICE_UUID       = "87654321-4321-4321-4321-ba0987654321";
static const char* ESP_NOTIFY_CHAR_UUID   = "11111111-2222-3333-4444-555555555555";
static const char* ESP_WRITE_CHAR_UUID    = "66666666-7777-8888-9999-aaaaaaaaaaaa";

// Optional: set Pi advertised device name here for easier matching
static const char* TARGET_PI_NAME = "SEAM_PI0";

// ======================================================
//                  GLOBAL STATE / DATA
// ======================================================

NimBLEAdvertisedDevice* foundPiDevice = nullptr;
NimBLEClient* piClient = nullptr;
NimBLERemoteCharacteristic* piRemoteChar = nullptr;

NimBLEServer* espServer = nullptr;
NimBLECharacteristic* espNotifyChar = nullptr;
NimBLECharacteristic* espWriteChar = nullptr;

bool piConnected = false;
bool appConnected = false;
bool shouldConnectToPi = false;
bool piFound = false;

// Latest data received from Pi
int heartRate = 0;
int spo2 = 0;
String latestPayload = "HR:0,SPO2:0";

// Timing
unsigned long lastScanAttempt = 0;
unsigned long lastStatusPrint = 0;
const unsigned long scanIntervalMs = 5000;

